## hohologgame 캐시 제어 헤더
## Netlify / Cloudflare Pages 로 이전 시 자동 적용됨
## GitHub Pages 는 이 파일을 무시하지만 보험용으로 포함

# HTML — 항상 서버에서 최신 확인
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin

# 루트 (index.html)
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# 버전 파일 — 항상 최신
/version.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# JS/CSS 파일 — 파일명에 해시 있으면 장기 캐시 허용
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# 이미지 — 1주일 캐시
/*.png
  Cache-Control: public, max-age=604800

/*.jpg
  Cache-Control: public, max-age=604800

/*.gif
  Cache-Control: public, max-age=604800
